# KingCom AI Agent config
PORT=8650
PUBLIC_BASE_URL=https://your-ngrok-or-production-url
ADMIN_TOKEN=change-me-long-random-token

# CORS for website widget/admin clients
CORS_ORIGINS=https://your-store-domain.example
CORS_ALLOW_ALL=false
JSON_BODY_LIMIT=1mb

# OpenRouter/OpenAI direct API
# Code accepts either OPENROUTER_API_KEY or OPENAI_API_KEY.
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/owl-alpha
OPENAI_MAX_OUTPUT_TOKENS=700
AI_TIMEOUT_MS=45000
SUMMARY_TIMEOUT_MS=30000
AUTO_REPLY=true
AI_TRACE_LOG=true

# Webhook verification
REQUIRE_WEBHOOK_SIGNATURES=true

# Facebook Messenger
FACEBOOK_VERIFY_TOKEN=change-me-facebook-verify-token
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=

# Zalo OA
ZALO_OA_ACCESS_TOKEN=
ZALO_APP_SECRET=

# Haravan
HARAVAN_WEBHOOK_SECRET=
HARAVAN_SHOP_DOMAIN=
HARAVAN_API_TOKEN=

# Staff alerts via Lark/Feishu Bot API
LARK_ALERT_ENABLED=true
LARK_APP_ID=
LARK_APP_SECRET=
LARK_RECEIVE_ID_TYPE=chat_id
LARK_RECEIVE_ID=

# Optional Telegram fallback if Lark fails
STAFF_TELEGRAM_CHAT_ID=
STAFF_TELEGRAM_BOT_TOKEN=
