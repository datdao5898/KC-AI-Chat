# KingCom AI Agent config
PORT=8650
PUBLIC_BASE_URL=https://your-ngrok-or-production-url

# PostgreSQL runtime database
# Local/VPS example: postgresql://kingcom:change-me@127.0.0.1:5432/kingcom_ai_agent
DATABASE_URL=
# Enable only when the PostgreSQL provider requires TLS.
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=true

# Admin dashboard login
ADMIN_USERNAME=admin
# Recommended: generate with `node src/hash-admin-password.js "your strong password"`
ADMIN_PASSWORD_HASH=
# Quick setup fallback. Prefer ADMIN_PASSWORD_HASH on production/VPS.
ADMIN_PASSWORD=change-me-admin-password
ADMIN_SESSION_SECRET=change-me-long-random-session-secret
ADMIN_SESSION_TTL_MS=43200000
ADMIN_COOKIE_SECURE=false
# Legacy token fallback for scripts. Leave blank if not needed.
ADMIN_TOKEN=

# CORS for website widget/admin clients
CORS_ORIGINS=https://your-store-domain.example
CORS_ALLOW_ALL=false
JSON_BODY_LIMIT=1mb

# OpenRouter/OpenAI direct API
# Code accepts either OPENROUTER_API_KEY or OPENAI_API_KEY.
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/owl-alpha
OPENAI_MAX_OUTPUT_TOKENS=700
AI_TIMEOUT_MS=45000
REPLY_JUDGE_ENABLED=true
OPENAI_JUDGE_MODEL=
OPENAI_JUDGE_MAX_OUTPUT_TOKENS=520
OPENAI_JUDGE_TIMEOUT_MS=45000
OPENAI_JUDGE_RETRIES=2
SUMMARY_TIMEOUT_MS=30000
AUTO_REPLY=true
AI_TRACE_LOG=true
AUTO_SUMMARY=true
AUTO_AI_SUMMARY=true
AUTO_SUMMARY_DELAY_MS=250

# Human-like reply pacing
HUMAN_REPLY_DELAY_ENABLED=true
HUMAN_REPLY_DELAY_MIN_MS=900
HUMAN_REPLY_DELAY_MAX_MS=6500
HUMAN_REPLY_DELAY_MS_PER_CHAR=10
HUMAN_REPLY_DELAY_MS_PER_LINE=220
HUMAN_REPLY_DELAY_JITTER_MS=500

# Webhook verification
REQUIRE_WEBHOOK_SIGNATURES=true

# Facebook Messenger
FACEBOOK_VERIFY_TOKEN=change-me-facebook-verify-token
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_NAME=
FACEBOOK_PAGE_ID=
# Optional maps for multiple fanpages. Accepts JSON or id:value pairs.
FACEBOOK_PAGE_TOKENS=111111111111111:token_page_1,222222222222222:token_page_2
FACEBOOK_PAGE_NAMES=111111111111111:Page 1,222222222222222:Page 2

# Zalo OA
ZALO_OA_ACCESS_TOKEN=
ZALO_APP_SECRET=
ZALO_OA_NAME=
ZALO_OA_ID=
ZALO_OA_NAMES=

# Haravan
HARAVAN_WEBHOOK_SECRET=
HARAVAN_SHOP_DOMAIN=
HARAVAN_API_TOKEN=

# Dashboard source labels for website conversations when widget payload has no site info.
DEFAULT_WEBSITE_NAME=
DEFAULT_WEBSITE_HOST=

# Staff alerts via Lark/Feishu Bot API
LARK_ALERT_ENABLED=true
LARK_APP_ID=
LARK_APP_SECRET=
LARK_RECEIVE_ID_TYPE=chat_id
# One or more group chat IDs, separated by commas.
LARK_RECEIVE_IDS=
# Backward-compatible single receive id fallback.
LARK_RECEIVE_ID=

# Optional Telegram fallback if Lark fails
STAFF_TELEGRAM_CHAT_ID=
STAFF_TELEGRAM_BOT_TOKEN=
